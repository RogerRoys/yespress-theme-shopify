<section class="yespress-highlights" id="YespressHighlights-{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <h2 class="yespress-highlights__heading" data-ys-reveal="up">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="yespress-highlights__viewport" data-ys-reveal="up" data-ys-delay="0.15">
      <div class="yespress-highlights__track" data-track>
        {%- for block in section.blocks -%}
          <div class="yespress-highlights__slide" role="group" aria-label="{{ forloop.index }} / {{ section.blocks.size }}" {{ block.shopify_attributes }}>
            <div class="yespress-highlights__slide-text">
              <p>{{ block.settings.text }}</p>
            </div>
            <div class="yespress-highlights__slide-media">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 1400
                  | image_tag: class: 'yespress-highlights__slide-image', widths: '760, 1080, 1400', sizes: '(max-width: 749px) 90vw, 46vw', alt: block.settings.image.alt
                }}
              {%- else -%}
                <div class="yespress-highlights__slide-placeholder">
                  {% render 'yespress-icons', name: 'logo' %}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="yespress-highlights__controls">
      <div class="yespress-highlights__dots" data-dots role="tablist" aria-label="Slides">
        {%- for block in section.blocks -%}
          <button
            type="button"
            class="yespress-highlights__dot{% if forloop.first %} is-active{% endif %}"
            data-index="{{ forloop.index0 }}"
            aria-label="Slide {{ forloop.index }}"
          ></button>
        {%- endfor -%}
      </div>
      <button type="button" class="yespress-highlights__playpause" data-playpause aria-label="Pause slideshow">
        <svg class="yespress-highlights__icon-pause" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <rect x="7" y="6" width="3.4" height="12" rx="1"/>
          <rect x="13.6" y="6" width="3.4" height="12" rx="1"/>
        </svg>
        <svg class="yespress-highlights__icon-play" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M8.5 6.2c0-.9 1-1.5 1.8-1l8.4 5.3c.74.46.74 1.54 0 2L10.3 17.8c-.8.5-1.8-.1-1.8-1V6.2Z"/>
        </svg>
      </button>
    </div>
  {%- endif -%}
</section>

{% style %}
  .yespress-highlights {
    background: #111112;
    padding: clamp(40px, 5vw, 72px) clamp(16px, 4vw, 60px) clamp(32px, 4vw, 56px);
  }

  .yespress-highlights__heading {
    font-family: var(--yespress-font);
    font-size: clamp(26px, 2.8vw, 40px);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--yespress-text);
    margin: 0 0 clamp(20px, 2.6vw, 40px);
  }

  .yespress-highlights__viewport {
    overflow: hidden;
    border-radius: clamp(20px, 2vw, 28px);
  }

  .yespress-highlights__track {
    display: flex;
    transition: transform 0.7s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .yespress-highlights__slide {
    flex: 0 0 100%;
    display: flex;
    align-items: center;
    gap: clamp(24px, 4vw, 64px);
    background: linear-gradient(160deg, #0b0b0c, #000 60%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: clamp(20px, 2vw, 28px);
    min-height: clamp(380px, 48vw, 480px);
    padding: clamp(24px, 3.6vw, 56px) clamp(24px, 5vw, 78px);
  }

  .yespress-highlights__slide-text {
    flex: 0 1 340px;
  }

  .yespress-highlights__slide-text p {
    margin: 0;
    font-family: var(--yespress-font);
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.55;
    color: var(--yespress-text);
  }

  .yespress-highlights__slide-media {
    flex: 1 1 auto;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .yespress-highlights__slide-image {
    max-width: 100%;
    max-height: clamp(300px, 40vw, 420px);
    object-fit: contain;
  }

  .yespress-highlights__slide-placeholder {
    width: clamp(180px, 24vw, 300px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 42%, rgba(0, 174, 66, 0.5), rgba(0, 174, 66, 0.08) 60%, transparent 75%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--yespress-text);
  }

  .yespress-highlights__slide-placeholder svg {
    width: 34%;
  }

  .yespress-highlights__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-top: clamp(20px, 2.4vw, 32px);
  }

  .yespress-highlights__dots {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #1d1d1f;
    border-radius: 100px;
    padding: 12px 18px;
  }

  .yespress-highlights__dot {
    position: relative;
    overflow: hidden;
    width: 7px;
    height: 7px;
    border-radius: 100px;
    border: none;
    padding: 0;
    background: rgba(245, 245, 247, 0.4);
    cursor: pointer;
    transition: width 0.35s ease, background 0.35s ease;
  }

  .yespress-highlights__dot.is-active {
    width: 30px;
    background: rgba(245, 245, 247, 0.35);
  }

  .yespress-highlights__dot.is-active::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: #f5f5f7;
    transform: scaleX(0);
    transform-origin: left center;
  }

  .yespress-highlights__dot.is-active.is-running::after {
    animation: ys-dot-progress 5s linear forwards;
  }

  .yespress-highlights.is-paused .yespress-highlights__dot.is-active::after {
    animation-play-state: paused;
  }

  @keyframes ys-dot-progress {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  .yespress-highlights__playpause {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: none;
    background: #1d1d1f;
    color: var(--yespress-text);
    cursor: pointer;
  }

  .yespress-highlights__playpause svg {
    width: 16px;
    height: 16px;
  }

  .yespress-highlights__playpause:hover {
    background: #2c2c2e;
  }

  .yespress-highlights__slide-image {
    filter: drop-shadow(0 30px 60px rgba(0, 0, 0, 0.6));
  }

  .yespress-highlights__playpause .yespress-highlights__icon-play,
  .yespress-highlights__playpause.is-paused .yespress-highlights__icon-pause {
    display: none;
  }

  .yespress-highlights__playpause.is-paused .yespress-highlights__icon-play {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .yespress-highlights__slide {
      flex-direction: column-reverse;
      align-items: center;
      text-align: center;
      min-height: 0;
    }

    .yespress-highlights__slide-text {
      flex-basis: auto;
    }
  }
{% endstyle %}

<script>
  (function () {
    var root = document.getElementById('YespressHighlights-{{ section.id }}');
    if (!root || root.dataset.bound) return;
    root.dataset.bound = 'true';

    var track = root.querySelector('[data-track]');
    var dots = Array.prototype.slice.call(root.querySelectorAll('.yespress-highlights__dot'));
    var playpause = root.querySelector('[data-playpause]');
    if (!track || dots.length < 1) return;

    var count = dots.length;
    var index = 0;
    var timer = null;
    var playing = true;
    var INTERVAL = 5000;

    function go(i) {
      index = (i + count) % count;
      track.style.transform = 'translateX(-' + index * 100 + '%)';
      dots.forEach(function (d, di) {
        d.classList.toggle('is-active', di === index);
        d.classList.remove('is-running');
      });
      var active = dots[index];
      void active.offsetWidth;
      if (playing) active.classList.add('is-running');
    }

    function stopTimer() {
      if (timer) { clearInterval(timer); timer = null; }
    }

    function startTimer() {
      stopTimer();
      if (count > 1 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        timer = setInterval(function () { go(index + 1); }, INTERVAL);
      }
    }

    dots.forEach(function (d) {
      d.addEventListener('click', function () {
        go(parseInt(d.dataset.index, 10));
        if (playing) startTimer();
      });
    });

    if (playpause) {
      playpause.addEventListener('click', function () {
        playing = !playing;
        playpause.classList.toggle('is-paused', !playing);
        root.classList.toggle('is-paused', !playing);
        if (playing) go(index);
        playpause.setAttribute('aria-label', playing ? 'Pause slideshow' : 'Play slideshow');
        playing ? startTimer() : stopTimer();
      });
    }

    /* Basic swipe */
    var startX = null;
    track.addEventListener('pointerdown', function (e) { startX = e.clientX; });
    track.addEventListener('pointerup', function (e) {
      if (startX === null) return;
      var dx = e.clientX - startX;
      if (Math.abs(dx) > 48) go(index + (dx < 0 ? 1 : -1));
      startX = null;
      if (playing) startTimer();
    });

    go(0);
    startTimer();
  })();
</script>

{% schema %}
{
  "name": "Yespress Highlights",
  "tag": "section",
  "class": "yespress-highlights-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "De highlights op een rij."
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque in nisl vel arcu vehicula lacinia id id lectus. Sed"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Yespress Highlights",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
