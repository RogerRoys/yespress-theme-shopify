<section class="yespress-cta-return">
  <div class="yespress-cta-return__content">
    {%- if section.settings.heading != blank -%}
      <h2 class="yespress-cta-return__heading" data-ys-words>{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p class="yespress-cta-return__text" data-ys-reveal="up" data-ys-delay="0.15">{{ section.settings.text }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link | default: '#' }}" class="yespress-cta-return__button" data-ys-reveal="up" data-ys-delay="0.28">
        {{- section.settings.button_label -}}
      </a>
    {%- endif -%}
  </div>

  <div class="yespress-cta-return__orbit" aria-hidden="true" data-ys-reveal="up" data-ys-delay="0.2">
    <span class="yespress-cta-return__glow"></span>
    <span class="yespress-cta-return__arc yespress-cta-return__arc--1"></span>
    <span class="yespress-cta-return__arc yespress-cta-return__arc--2"></span>
    <span class="yespress-cta-return__arc yespress-cta-return__arc--3"></span>
    {%- for block in section.blocks -%}
      <div
        class="yespress-cta-return__tile"
        data-ys-float
        style="--tile-x: {{ block.settings.pos_x }}%; --tile-y: {{ block.settings.pos_y }}px; --tile-r: {{ block.settings.rotate }}deg;"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 200 | image_tag: class: 'yespress-cta-return__tile-image', alt: block.settings.label }}
        {%- else -%}
          <span class="yespress-cta-return__stamp">{{ block.settings.label }}</span>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% style %}
  .yespress-cta-return {
    position: relative;
    background: #000;
    padding: clamp(64px, 8vw, 110px) 24px 0;
    overflow: hidden;
    text-align: center;
  }

  .yespress-cta-return__content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
  }

  .yespress-cta-return__heading {
    font-family: var(--yespress-font);
    font-size: clamp(32px, 4.4vw, 58px);
    line-height: 1.12;
    letter-spacing: -0.015em;
    font-weight: 700;
    color: var(--yespress-text);
    max-width: 680px;
    margin: 0 auto 20px;
  }

  .yespress-cta-return__text {
    font-family: var(--yespress-font);
    font-size: clamp(13px, 1vw, 15px);
    line-height: 1.5;
    color: rgba(245, 245, 247, 0.7);
    max-width: 560px;
    margin: 0 auto 28px;
  }

  .yespress-cta-return__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--yespress-green);
    color: #fff;
    font-family: var(--yespress-font);
    font-size: 14px;
    font-weight: 500;
    border-radius: 980px;
    padding: 12px 24px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .yespress-cta-return__button:hover {
    background: var(--yespress-green-hover);
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 8px 30px rgba(0, 174, 66, 0.45);
  }

  .yespress-cta-return__orbit {
    position: relative;
    height: clamp(240px, 26vw, 380px);
    margin-top: clamp(32px, 4vw, 56px);
  }

  .yespress-cta-return__arc {
    position: absolute;
    left: 50%;
    border: 1px solid rgba(245, 245, 247, 0.14);
    border-radius: 50%;
    transform: translateX(-50%);
  }

  .yespress-cta-return__arc--1 { width: 62vw; aspect-ratio: 1; top: 24%; }
  .yespress-cta-return__arc--2 { width: 88vw; aspect-ratio: 1; top: 12%; }
  .yespress-cta-return__arc--3 { width: 114vw; aspect-ratio: 1; top: 0; }

  .yespress-cta-return__tile {
    position: absolute;
    left: var(--tile-x, 50%);
    top: var(--tile-y, 40px);
    transform: translateX(-50%) rotate(var(--tile-r, 0deg));
    width: clamp(52px, 6vw, 72px);
    aspect-ratio: 1;
    background: #fff;
    border-radius: 22%;
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.65), 0 2px 8px rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .yespress-cta-return__tile-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .yespress-cta-return__stamp {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    width: 74%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: #d0201f;
    color: #fff;
    font-family: var(--yespress-font);
    font-size: 8px;
    font-weight: 800;
    line-height: 1.15;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    padding: 4px;
  }

  @media screen and (max-width: 749px) {
    .yespress-cta-return__orbit {
      height: 220px;
    }

    .yespress-cta-return__arc--1 { width: 120vw; }
    .yespress-cta-return__arc--2 { width: 170vw; }
    .yespress-cta-return__arc--3 { width: 220vw; }
  }
  .yespress-cta-return__orbit {
    -webkit-mask-image: linear-gradient(180deg, #000 58%, transparent 100%);
    mask-image: linear-gradient(180deg, #000 58%, transparent 100%);
  }

  .yespress-cta-return__glow {
    position: absolute;
    left: 50%;
    bottom: -45%;
    width: 74vw;
    aspect-ratio: 2.1;
    transform: translateX(-50%);
    background: radial-gradient(closest-side, rgba(0, 174, 66, 0.22), transparent 72%);
    filter: blur(34px);
    pointer-events: none;
  }
{% endstyle %}

{% schema %}
{
  "name": "Yespress CTA Return",
  "tag": "section",
  "class": "yespress-cta-return-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop with Confidence, Risk-Free for 30 Days"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Shop confidently knowing that if your purchase doesn't feel quite right, you can return it within 30 days at no additional cost, making your shopping experience safer, easier, and completely worry-free."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Try for Free Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Floating badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Badge image",
          "info": "Square icon. Leave empty to show a red stamp with the label below."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Free 30 Day"
        },
        {
          "type": "range",
          "id": "pos_x",
          "label": "Horizontal position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 50
        },
        {
          "type": "range",
          "id": "pos_y",
          "label": "Vertical offset",
          "min": 0,
          "max": 300,
          "step": 5,
          "unit": "px",
          "default": 60
        },
        {
          "type": "range",
          "id": "rotate",
          "label": "Rotation",
          "min": -20,
          "max": 20,
          "step": 1,
          "unit": "deg",
          "default": 0
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Yespress CTA Return",
      "blocks": [
        { "type": "tile", "settings": { "label": "Free Shipping", "pos_x": 22, "pos_y": 105, "rotate": -10 } },
        { "type": "tile", "settings": { "label": "Free 30 Day", "pos_x": 50, "pos_y": 45, "rotate": 6 } },
        { "type": "tile", "settings": { "label": "Money Back Guarantee", "pos_x": 78, "pos_y": 110, "rotate": 9 } }
      ]
    }
  ]
}
{% endschema %}
