<footer class="yespress-footer">
  <div class="yespress-footer__top">
    <div class="yespress-footer__cta" data-ys-reveal="up">
      {%- if section.settings.heading != blank -%}
        <h2 class="yespress-footer__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      <div class="yespress-footer__badges">
        {%- if section.settings.playstore_label != blank -%}
          {% render 'yespress-store-badge', store: 'playstore', label: section.settings.playstore_label, link: section.settings.playstore_link, style: 'light' %}
        {%- endif -%}
        {%- if section.settings.appstore_label != blank -%}
          {% render 'yespress-store-badge', store: 'appstore', label: section.settings.appstore_label, link: section.settings.appstore_link, style: 'green' %}
        {%- endif -%}
      </div>
    </div>

    <div class="yespress-footer__cols" data-ys-stagger>
      <div class="yespress-footer__col">
        {%- if section.settings.menu_1_title != blank -%}
          <h3 class="yespress-footer__col-title">{{ section.settings.menu_1_title }}</h3>
        {%- endif -%}
        <ul class="yespress-footer__menu">
          {%- if section.settings.menu_1 != blank -%}
            {%- for link in section.settings.menu_1.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="#">Features</a></li>
            <li><a href="#">Pricing</a></li>
            <li><a href="#">Resources</a></li>
            <li><a href="#">Support</a></li>
          {%- endif -%}
        </ul>
      </div>

      <div class="yespress-footer__col">
        {%- if section.settings.menu_2_title != blank -%}
          <h3 class="yespress-footer__col-title">{{ section.settings.menu_2_title }}</h3>
        {%- endif -%}
        <ul class="yespress-footer__menu">
          {%- if section.settings.menu_2 != blank -%}
            {%- for link in section.settings.menu_2.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="#">Faq</a></li>
            <li><a href="#">Service Center</a></li>
            <li><a href="#">Help Center</a></li>
          {%- endif -%}
        </ul>
      </div>

      <div class="yespress-footer__col yespress-footer__col--newsletter">
        {%- if section.settings.newsletter_title != blank -%}
          <h3 class="yespress-footer__col-title">{{ section.settings.newsletter_title }}</h3>
        {%- endif -%}
        {%- if section.settings.newsletter_text != blank -%}
          <p class="yespress-footer__newsletter-text">{{ section.settings.newsletter_text }}</p>
        {%- endif -%}
        {%- form 'customer', class: 'yespress-footer__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="yespress-footer__input-wrap">
            <label class="visually-hidden" for="YespressNewsletter-{{ section.id }}">{{ section.settings.newsletter_placeholder | default: 'Enter your email' }}</label>
            <input
              id="YespressNewsletter-{{ section.id }}"
              type="email"
              name="contact[email]"
              class="yespress-footer__input"
              placeholder="{{ section.settings.newsletter_placeholder | default: 'Enter your email' }}"
              required
              autocomplete="email"
            >
            <button type="submit" class="yespress-footer__submit">{{ section.settings.newsletter_button | default: 'Join' }}</button>
          </div>
          {%- if form.posted_successfully? -%}
            <p class="yespress-footer__form-msg yespress-footer__form-msg--ok">Bedankt voor je aanmelding!</p>
          {%- elsif form.errors -%}
            <p class="yespress-footer__form-msg yespress-footer__form-msg--error">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>
  </div>

  <div class="yespress-footer__bottom">
    <p class="yespress-footer__copyright">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All Rights Reserved.
    </p>
    <div class="yespress-footer__socials">
      {%- if section.settings.social_facebook != blank -%}
        <a href="{{ section.settings.social_facebook }}" aria-label="Facebook" target="_blank" rel="noopener">{% render 'yespress-icons', name: 'facebook' %}</a>
      {%- endif -%}
      {%- if section.settings.social_instagram != blank -%}
        <a href="{{ section.settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">{% render 'yespress-icons', name: 'instagram' %}</a>
      {%- endif -%}
      {%- if section.settings.social_threads != blank -%}
        <a href="{{ section.settings.social_threads }}" aria-label="Threads" target="_blank" rel="noopener">{% render 'yespress-icons', name: 'threads' %}</a>
      {%- endif -%}
    </div>
  </div>
</footer>

{% style %}
  .yespress-footer {
    background: #000;
    padding: clamp(40px, 5vw, 64px) clamp(24px, 4.2vw, 64px) 0;
    font-family: var(--yespress-font);
  }

  .yespress-footer__top {
    display: grid;
    grid-template-columns: minmax(280px, 1fr) 2fr;
    gap: clamp(32px, 5vw, 80px);
    padding-bottom: clamp(40px, 6vw, 90px);
  }

  .yespress-footer__cta {
    border-right: 1px solid rgba(245, 245, 247, 0.14);
    padding-right: clamp(24px, 3vw, 48px);
  }

  .yespress-footer__heading {
    font-size: clamp(24px, 2.2vw, 32px);
    line-height: 1.3;
    font-weight: 700;
    color: var(--yespress-text);
    margin: 0 0 28px;
    max-width: 320px;
  }

  .yespress-footer__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .yespress-footer__badges .yespress-badge {
    padding: 10px 16px;
    font-size: 12px;
  }

  .yespress-footer__cols {
    display: grid;
    grid-template-columns: 1fr 1fr 1.4fr;
    gap: clamp(24px, 3vw, 48px);
  }

  .yespress-footer__col-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--yespress-text);
    margin: 0 0 22px;
  }

  .yespress-footer__menu {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .yespress-footer__menu a {
    font-size: 14px;
    color: rgba(245, 245, 247, 0.65);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .yespress-footer__menu a:hover {
    color: var(--yespress-text);
  }

  .yespress-footer__newsletter-text {
    font-size: 14px;
    line-height: 1.5;
    color: rgba(245, 245, 247, 0.65);
    margin: 0 0 20px;
  }

  .yespress-footer__input-wrap {
    display: flex;
    align-items: center;
    background: #fff;
    border-radius: 100px;
    padding: 4px 4px 4px 18px;
    max-width: 360px;
  }

  .yespress-footer__input {
    flex: 1 1 auto;
    min-width: 0;
    border: none;
    background: none;
    font-family: var(--yespress-font);
    font-size: 14px;
    color: #0b0b0c;
    outline: none;
  }

  .yespress-footer__input::placeholder {
    color: #86868b;
  }

  .yespress-footer__submit {
    flex-shrink: 0;
    background: var(--yespress-green);
    color: #fff;
    border: none;
    border-radius: 100px;
    font-family: var(--yespress-font);
    font-size: 14px;
    font-weight: 600;
    padding: 11px 22px;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .yespress-footer__submit:hover {
    background: var(--yespress-green-hover);
  }

  .yespress-footer__form-msg {
    font-size: 13px;
    margin: 10px 0 0;
  }

  .yespress-footer__form-msg--ok { color: var(--yespress-green); }
  .yespress-footer__form-msg--error { color: #ff6b6b; }

  .yespress-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-top: 1px solid rgba(245, 245, 247, 0.14);
    padding: 22px 0 28px;
  }

  .yespress-footer__copyright {
    font-size: 13px;
    color: rgba(245, 245, 247, 0.75);
    margin: 0;
  }

  .yespress-footer__socials {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .yespress-footer__socials a {
    display: inline-flex;
    color: var(--yespress-text);
    transition: color 0.15s ease;
  }

  .yespress-footer__socials a:hover {
    color: var(--yespress-green);
  }

  .yespress-footer__socials svg {
    width: 17px;
    height: 17px;
  }

  @media screen and (max-width: 989px) {
    .yespress-footer__top {
      grid-template-columns: 1fr;
    }

    .yespress-footer__cta {
      border-right: none;
      border-bottom: 1px solid rgba(245, 245, 247, 0.14);
      padding-right: 0;
      padding-bottom: 32px;
    }
  }

  @media screen and (max-width: 749px) {
    .yespress-footer__cols {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .yespress-footer__bottom {
      flex-direction: column-reverse;
      align-items: flex-start;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Yespress Footer",
  "tag": "footer",
  "class": "yespress-footer-wrapper",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Start Your Journey with Yespress Now!"
    },
    {
      "type": "header",
      "content": "Store badges"
    },
    {
      "type": "text",
      "id": "playstore_label",
      "label": "Play Store label",
      "default": "Get on Playstore"
    },
    {
      "type": "url",
      "id": "playstore_link",
      "label": "Play Store link"
    },
    {
      "type": "text",
      "id": "appstore_label",
      "label": "App Store label",
      "default": "Get on Appstore"
    },
    {
      "type": "url",
      "id": "appstore_link",
      "label": "App Store link"
    },
    {
      "type": "header",
      "content": "Menus"
    },
    {
      "type": "text",
      "id": "menu_1_title",
      "label": "Menu 1 title",
      "default": "Company"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menu 1"
    },
    {
      "type": "text",
      "id": "menu_2_title",
      "label": "Menu 2 title",
      "default": "Resources"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menu 2"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Title",
      "default": "Stay Updated"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Text",
      "default": "Subscribe to our newsletter for marketing insights"
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Input placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "newsletter_button",
      "label": "Button label",
      "default": "Join"
    },
    {
      "type": "header",
      "content": "Social"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram"
    },
    {
      "type": "url",
      "id": "social_threads",
      "label": "Threads"
    }
  ],
  "presets": [
    {
      "name": "Yespress Footer"
    }
  ]
}
{% endschema %}
