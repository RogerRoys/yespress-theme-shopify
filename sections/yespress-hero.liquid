<section class="yespress-hero{% if section.settings.full_height %} yespress-hero--full{% endif %}">
  <div class="yespress-hero__media" aria-hidden="true">
    {%- if section.settings.video != blank -%}
      {{
        section.settings.video
        | video_tag: class: 'yespress-hero__video', autoplay: true, loop: section.settings.video_loop, muted: true, controls: false, playsinline: true
      }}
    {%- elsif section.settings.use_default_video -%}
      <video
        class="yespress-hero__video"
        autoplay
        {% if section.settings.video_loop %}loop{% endif %}
        muted
        playsinline
        preload="metadata"
        {% if section.settings.image != blank %}poster="{{ section.settings.image | image_url: width: 1600 }}"{% endif %}
      >
        <source src="{{ 'yespress-hero.mp4' | asset_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1880
        | image_tag: class: 'yespress-hero__image', widths: '760, 1080, 1600, 1880', sizes: '(max-width: 749px) 100vw, 62vw', alt: section.settings.image.alt
      }}
    {%- else -%}
      <div class="yespress-hero__placeholder"></div>
    {%- endif -%}
  </div>

  <div class="yespress-hero__content">
    <div class="yespress-hero__text">
      <div class="yespress-hero__brand">
        {%- if section.settings.show_logo_mark -%}
          <span class="yespress-hero__brand-mark">{% render 'yespress-icons', name: 'logo' %}</span>
        {%- endif -%}
        <h1 class="yespress-hero__brand-name">
          <strong>{{ section.settings.brand_bold }}</strong>
          {%- if section.settings.brand_regular != blank %} <span>{{ section.settings.brand_regular }}</span>{% endif -%}
        </h1>
      </div>
      {%- if section.settings.heading != blank -%}
        <p class="yespress-hero__heading">{{ section.settings.heading }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.buy_label != blank -%}
      <div class="yespress-hero__offer">
        {%- if section.settings.price_text != blank -%}
          <span class="yespress-hero__price">{{ section.settings.price_text }}</span>
        {%- endif -%}
        <a href="{{ section.settings.buy_link | default: '#' }}" class="yespress-hero__buy">
          {{- section.settings.buy_label -}}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% style %}
  .yespress-hero {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: var(--yespress-bg, #000);
    min-height: 640px;
    overflow: hidden;
  }

  .yespress-hero--full {
    min-height: max(640px, calc(100svh - 60px));
  }

  .yespress-hero__media {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 26%;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    pointer-events: none;
  }

  .yespress-hero__image,
  .yespress-hero__video {
    width: min(940px, 66vw);
    height: 118%;
    object-fit: contain;
    object-position: center top;
  }

  .yespress-hero__placeholder {
    width: min(720px, 60vw);
    aspect-ratio: 1;
    margin-top: -8%;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 38%, rgba(0, 174, 66, 0.55) 0%, rgba(0, 174, 66, 0.12) 34%, transparent 62%);
  }

  .yespress-hero__content {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
    width: 100%;
    padding: 0 clamp(24px, 8vw, 120px) clamp(40px, 5.5vw, 80px);
  }

  .yespress-hero__text {
    display: flex;
    flex-direction: column;
    gap: clamp(8px, 1vw, 13px);
    max-width: 664px;
  }

  .yespress-hero__brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .yespress-hero__brand-mark {
    display: inline-flex;
    color: var(--yespress-text);
    flex-shrink: 0;
  }

  .yespress-hero__brand-mark svg {
    width: clamp(23px, 2.7vw, 40px);
    height: auto;
  }

  .yespress-hero__brand-name {
    font-family: var(--yespress-font);
    font-size: clamp(18px, 2.2vw, 32px);
    line-height: 1.35;
    color: var(--yespress-text);
    font-weight: 400;
    margin: 0;
  }

  .yespress-hero__brand-name strong {
    font-weight: 700;
  }

  .yespress-hero__heading {
    font-family: var(--yespress-font);
    font-size: clamp(42px, 4.9vw, 74px);
    line-height: 1.135;
    letter-spacing: -0.01em;
    font-weight: 700;
    color: var(--yespress-text);
    margin: 0;
  }

  .yespress-hero__offer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    background: var(--yespress-pill, #424245);
    border-radius: 100px;
    padding: 10px 10px 10px 28px;
    min-width: 224px;
    flex-shrink: 0;
  }

  .yespress-hero__price {
    font-family: var(--yespress-font);
    font-size: 16px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--yespress-text);
    white-space: nowrap;
  }

  .yespress-hero__buy {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--yespress-green, #00ae42);
    color: #fff;
    font-family: var(--yespress-font-display);
    font-size: 17px;
    letter-spacing: -0.022em;
    line-height: 1.3;
    border-radius: 980px;
    padding: 9px 16px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s ease;
  }

  .yespress-hero__buy:hover {
    background: var(--yespress-green-hover, #00c24a);
  }

  @media screen and (max-width: 749px) {
    .yespress-hero__media {
      bottom: 32%;
    }

    .yespress-hero__image,
    .yespress-hero__video {
      width: min(560px, 100vw);
      height: 112%;
    }

    .yespress-hero__content {
      flex-direction: column;
      align-items: stretch;
      gap: 24px;
      padding-bottom: 36px;
    }

    .yespress-hero__text {
      align-items: center;
      text-align: center;
      max-width: none;
    }

    .yespress-hero__offer {
      width: 100%;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Yespress Hero",
  "tag": "section",
  "class": "yespress-hero-wrapper",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Hero video",
      "info": "Optional override. When empty, the bundled Yespress hero animation is used."
    },
    {
      "type": "checkbox",
      "id": "use_default_video",
      "label": "Use bundled hero video",
      "info": "Plays the Yespress hero animation shipped with the theme when no video is selected above.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "Loop video",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback / poster image",
      "info": "Shown while the video loads, or instead of it when videos are disabled."
    },
    {
      "type": "checkbox",
      "id": "show_logo_mark",
      "label": "Show logo mark",
      "default": true
    },
    {
      "type": "text",
      "id": "brand_bold",
      "label": "Brand name (bold part)",
      "default": "YESPRESS"
    },
    {
      "type": "text",
      "id": "brand_regular",
      "label": "Brand name (regular part)",
      "default": "EEN"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Altijd gerust."
    },
    {
      "type": "text",
      "id": "price_text",
      "label": "Price text",
      "default": "Voor € 149"
    },
    {
      "type": "text",
      "id": "buy_label",
      "label": "Buy button label",
      "default": "Koop"
    },
    {
      "type": "url",
      "id": "buy_link",
      "label": "Buy button link"
    },
    {
      "type": "checkbox",
      "id": "full_height",
      "label": "Full viewport height",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Yespress Hero"
    }
  ]
}
{% endschema %}
