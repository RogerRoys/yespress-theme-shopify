{
  "name": "Instagram Gallery",
  "tag": null,
  "class": "instagram-gallery-block",
  "settings": [
    {
      "type": "header",
      "content": "Gallery Settings"
    },
    {
      "type": "range",
      "id": "number_of_images",
      "min": 1,
      "max": 15,
      "step": 1,
      "label": "Number of images to display",
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "auto_scroll",
      "label": "Enable auto-scroll",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "auto",
          "label": "Auto"
        },
        {
          "value": "square",
          "label": "Square"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "landscape",
          "label": "Landscape"
        }
      ],
      "default": "square"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "s",
      "label": "Auto-scroll speed",
      "default": 30
    },
    {
      "type": "range",
      "id": "transition_speed",
      "min": 0.2,
      "max": 1,
      "step": 0.1,
      "unit": "s",
      "label": "Transition speed",
      "default": 0.5
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 40,
      "step": 4,
