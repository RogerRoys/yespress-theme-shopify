{% comment %}
  Inline SVG icons recreated from the Figma design (proxy-safe, no external assets).
  Usage: {% render 'yespress-icons', name: 'logo' %}
{% endcomment %}
{%- case name -%}
  {%- when 'logo' -%}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 40 43" fill="none">
      <path d="M7.5 21.5L16.2 30.2L34.5 8" stroke="currentColor" stroke-width="8.6" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="8.2" cy="38.2" r="4.3" fill="currentColor"/>
    </svg>
  {%- when 'search' -%}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none">
      <circle cx="10.5" cy="10.5" r="7" stroke="currentColor" stroke-width="1.6"/>
      <path d="M15.8 15.8L21 21" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>
  {%- when 'bag' -%}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none">
      <path d="M8.25 8V6.75a3.75 3.75 0 0 1 7.5 0V8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <path d="M4.9 8h14.2a1 1 0 0 1 1 .93l.85 11a1.5 1.5 0 0 1-1.5 1.62H4.55a1.5 1.5 0 0 1-1.5-1.62l.85-11A1 1 0 0 1 4.9 8Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>
  {%- when 'hamburger' -%}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none">
      <path d="M4 8h16M4 16h16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>
  {%- when 'close' -%}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none">
      <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>
{%- endcase -%}
