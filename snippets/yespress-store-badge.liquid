{% comment %}
  App store badge pill.
  Usage: {% render 'yespress-store-badge', store: 'playstore', label: 'Get on Playstore', link: '#', style: 'light' %}
  store: 'playstore' | 'appstore' — style: 'light' | 'green'
{% endcomment %}
<a href="{{ link | default: '#' }}" class="yespress-badge yespress-badge--{{ style | default: 'light' }}">
  <span class="yespress-badge__icon">
    {%- if store == 'appstore' -%}
      <svg aria-hidden="true" focusable="false" viewBox="0 0 384 512" fill="currentColor">
        <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/>
      </svg>
    {%- else -%}
      <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24">
        <path fill="#00c4ff" d="M3.6 1.9 13.6 12 3.6 22.1c-.37-.28-.6-.76-.6-1.35V3.25c0-.59.23-1.07.6-1.35Z"/>
        <path fill="#00e676" d="M3.6 1.9c.3-.23.72-.3 1.13-.08l12.32 6.53-3.42 3.65L3.6 1.9Z"/>
        <path fill="#f44336" d="M13.63 12l3.42 3.65-12.32 6.53c-.41.22-.83.15-1.13-.08L13.63 12Z"/>
        <path fill="#ffce00" d="M17.05 8.35 20.9 10.4c1.13.6 1.13 2.6 0 3.2l-3.85 2.05L13.63 12l3.42-3.65Z"/>
      </svg>
    {%- endif -%}
  </span>
  <span class="yespress-badge__label">{{ label }}</span>
</a>
